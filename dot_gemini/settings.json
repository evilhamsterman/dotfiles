{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "context": {
    "fileName": [
      "AGENTS.md",
      "GEMINI.md"
    ]
  },
  "general": {
    "vimMode": true,
    "defaultApprovalMode": "plan",
    "hideTips": true,
    "sessionRetention": {
      "warningAcknowledged": true,
      "enabled": true,
      "maxAge": "120d"
    }
  },
  "experimental": {
    "enableAgents": true,
    "modelSteering": true
  },
  "ui": {
    "theme": "GitHub",
    "loadingPhrases": "off"
  },
  "tools": {
    "shell": {
      "showColor": true
    }
  },
  "ide": {
    "hasSeenNudge": true,
    "enabled": true
  },
  "mcpServers": {
        "github": {
            "command": "docker",
            "args": [
                "run",
                "-i",
                "--rm",
                "-e",
                "GITHUB_PERSONAL_ACCESS_TOKEN",
                "ghcr.io/github/github-mcp-server"
            ],
            "env": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "$GITHUB_MCP_PAT"
            }
        }
    }
}
