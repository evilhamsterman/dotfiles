{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "context": {
    "fileName": [
      "AGENTS.md",
      "GEMINI.md"
    ]
  },
  "general": {
    "vimMode": true,
    "defaultApprovalMode": "plan",
    "hideTips": true,
    "sessionRetention": {
      "warningAcknowledged": true,
      "enabled": true,
      "maxAge": "120d"
    }
  },
  "experimental": {
    "enableAgents": true,
    "modelSteering": true
  },
  "ui": {
    "theme": "GitHub",
    "loadingPhrases": "off"
  },
  "tools": {
    "shell": {
      "showColor": true
    }
  },
  "ide": {
    "hasSeenNudge": true,
    "enabled": true
  }
}